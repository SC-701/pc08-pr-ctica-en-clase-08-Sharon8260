@page
@model Producto.WEB.Pages.Productos.IndexModel
@{
}

<h1 class="mb-4 text-center">🛍️ Listado de Productos</h1>

<div class="container">
    <div class="text-center mb-4">
        <a type="button" class="btn btn-success" asp-page="./Agregar">Agregar producto</a>
    </div>

    <div class="row">
        @if (Model.productos != null && Model.productos.Any())
        {
            @foreach (var producto in Model.productos)
            {
                <div class="col-md-4 mb-4">
                    <div class="card shadow-sm h-100">
                        <div class="card-body">

                            <h5 class="card-title text-primary">
                                @producto.Nombre
                            </h5>

                            <p class="card-text">
                                <strong>Categoría:</strong> @producto.Categoria
                            </p>

                            <p class="card-text">
                                <strong>SubCategoría:</strong> @producto.SubCategoria
                            </p>

                            <p class="card-text">
                                <strong>Precio:</strong> ₡@producto.Precio
                            </p>

                            <p class="card-text">
                                <strong>Stock:</strong> @producto.Stock
                            </p>

                            <a type="button" class="btn btn-primary"
                               asp-page="./Detalle"
                               asp-route-id="@producto.Id">
                                Detalle
                            </a>

                            <a type="button" class="btn btn-warning"
                               asp-page="./Editar"
                               asp-route-id="@producto.Id">
                                Editar
                            </a>

                            <a type="button" class="btn btn-danger"
                               asp-page="./Eliminar"
                               asp-route-id="@producto.Id">
                                Eliminar
                            </a>

                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="alert alert-info text-center">
                No hay productos registrados 🚫
            </div>
        }
    </div>
</div>